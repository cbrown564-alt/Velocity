    },
    {
      "id": "deck-slide-1-1773412108003",
      "title": "Nearly Half of Respondents Report Having a Sleep Problem",
      "subtitle": "N = 271 Respondents",
      "notes": "Roughly 43.5% of valid respondents say they have a sleep problem. That creates a substantial subgroup for examining where sleep disruption shows up most clearly in daily life.",
      "analysisState": {
        "rowVars": [
          "vs_problem"
        ],
        "colVar": null,
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
      "chartType": "horizontal-bar",
      "layoutMode": "focus",
      "cells": [
        {
          "id": "deck-slide-1-1773412108003-cell-1",
          "content": {
            "type": "table"
          }
        }
      ],
      "sectionId": "deck-section-0-1773412108003",
      "createdAt": 1773412108003,
      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-2-1773412108003",
      "title": "Night Waking Rises Sharply With Age",
      "subtitle": "N = 271 Respondents",
      "notes": "The share reporting waking during the night rises from 65.1% among the youngest group to 91.1% among adults aged 51+, with a chi-square p-value below 0.001. This is the clearest demographic gradient in the dataset.",
      "analysisState": {
        "rowVars": [
          "heuristic_multiple_troublefallasleep_troublestaysleep_wakenite_lightsleeper_refreshed"
        ],
        "colVar": "vs_age3gp",
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
      "chartType": "grouped-bar",
      "layoutMode": "focus",
      "cells": [
        {
          "id": "deck-slide-2-1773412108003-cell-1",
          "content": {
            "type": "table"
          }
        }
      ],
      "sectionId": "deck-section-0-1773412108003",
      "createdAt": 1773412108003,
      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-3-1773412108003",
      "title": "Women Report Higher Anxiety Than Men in This Sample",
      "subtitle": "N = 271 Respondents",
      "notes": "Average HADS anxiety is 7.1 for women versus 5.4 for men in this dataset. The gap is descriptive rather than explanatory, but it provides context for later slides that connect sleep quality to mental-health strain.",
      "analysisState": {
        "rowVars": [
          "vs_anxiety"
        ],
        "colVar": "vs_sex",
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
      "chartType": "grouped-box-plot",
      "layoutMode": "focus",
      "cells": [
        {
          "id": "deck-slide-3-1773412108003-cell-1",
          "content": {
            "type": "table"
          }
        }
      ],
      "sectionId": "deck-section-1-1773412108003",
      "createdAt": 1773412108003,
      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-4-1773412108003",
      "title": "Anxiety Scores Climb as Sleep Quality Worsens",
      "subtitle": "N = 271 Respondents",
      "notes": "Mean anxiety rises from 4.7 among people with very good or excellent sleep to 8.3 among those with poor sleep. That roughly 3.5-point spread makes the anxiety-sleep link one of the strongest stories in the dataset.",
      "analysisState": {
        "rowVars": [
          "vs_anxiety"
        ],
        "colVar": "vs_qualsleep4gp",
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
      "chartType": "grouped-box-plot",
      "layoutMode": "focus",
      "cells": [
        {
          "id": "deck-slide-4-1773412108003-cell-1",
          "content": {
            "type": "table"
          }
        }
      ],
      "sectionId": "deck-section-1-1773412108003",
      "createdAt": 1773412108003,
      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-5-1773412108003",
      "title": "Depression Follows the Same Gradient, but More Gently",
      "subtitle": "N = 271 Respondents",
      "notes": "Depression scores also rise as reported sleep quality worsens, moving from 2.3 in the best-sleep group to 5.1 in the worst-sleep group. The slope is gentler than it is for anxiety, suggesting anxiety is the sharper mental-health correlate here.",
      "analysisState": {
        "rowVars": [
          "vs_depress"
        ],
        "colVar": "vs_qualsleep4gp",
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
      "chartType": "grouped-box-plot",
      "layoutMode": "focus",
      "cells": [
        {
          "id": "deck-slide-5-1773412108003-cell-1",
          "content": {
            "type": "table"
          }
        }
      ],
      "sectionId": "deck-section-1-1773412108003",
      "createdAt": 1773412108003,
      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-6-1773412108003",
      "title": "Sleep Problems Become More Common as Stress Levels Rise",
      "subtitle": "N = 271 Respondents",
      "notes": "Only 3.8% of respondents at stress score 2 report a sleep problem, compared with 61.9% at stress score 9 and 83.3% at the maximum stress point. Even with the rough scale labels, the direction is strong and highly significant.",
      "analysisState": {
        "rowVars": [
          "vs_problem"
        ],
        "colVar": "vs_stressmonth",
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
      "chartType": "grouped-bar",
      "layoutMode": "focus",
      "cells": [
        {
          "id": "deck-slide-6-1773412108003-cell-1",
          "content": {
            "type": "table"
          }
        }
      ],
