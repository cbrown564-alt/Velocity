      "createdAt": 1773412108003,
      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-8-1773412108003",
      "title": "Daytime Sleepiness Appears Across All Ages, With a Mild Peak in Older Adults",
      "subtitle": "N = 271 Respondents",
      "notes": "Epworth sleepiness scores are present across the full sample, not concentrated in a single age band. Older adults have the highest average score at 7.2, but the bigger age story remains nighttime disruption rather than a dramatic daytime divide.",
      "analysisState": {
        "rowVars": [
          "vs_ess"
        ],
        "colVar": "vs_age3gp",
        "filters": [],
        "weightVar": null
      },
      "visualizationType": "chart",
