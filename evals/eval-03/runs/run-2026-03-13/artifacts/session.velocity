      "updatedAt": 1773412108003
    },
    {
      "id": "deck-slide-7-1773412108003",
      "title": "Among People With Sleep Problems, Energy Is the Most Consistently Affected Domain",
      "subtitle": "Filtered: problem = 1 · N = 271 Respondents",
      "notes": "Within the sleep-problem subgroup, energy has the highest average impact score of the seven downstream life domains at 6.5 out of 10. Mood, concentration, and overall well-being also score high, but energy stands out as the clearest day-to-day burden.",
      "analysisState": {
        "rowVars": [
          "heuristic_grid_impact2_impact3_impact4_impact5_impact6"
        ],
