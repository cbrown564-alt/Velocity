  "slides": [
    {
      "id": "deck-slide-0-1773412108003",
      "title": "Sleep Is Usually Adequate, but Poor Sleep Still Matters",
      "subtitle": "N = 271 Respondents",
      "notes": "About one-third of valid respondents report good sleep and another 28% report fair sleep, while 13% fall into the very poor or poor category. The sample therefore looks mixed rather than uniformly well rested.",
      "analysisState": {
        "rowVars": [
          "vs_qualsleep4gp"
