{
  "name": "velocity",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "mcp-server"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:test",
    "check:worker-boundary": "node scripts/check-worker-boundary.mjs",
    "check:querybuilder-pure": "node scripts/check-querybuilder-pure.mjs",
    "velocity-mcp-setup": "node scripts/velocity-mcp-setup.mjs",
    "mcp:build": "vitest run mcp-server/__tests__/tools.test.ts",
    "mcp:dev": "npm run dev -w @velocity/mcp-server",
    "eval:05": "node scripts/eval/run-eval-05.mjs",
    "eval:06": "node scripts/eval/run-eval-06.mjs",
    "benchmark:sav": "npx tsx scripts/benchmark-sav-ingestion.ts",
    "benchmark:sav:v2v3": "npx tsx scripts/benchmark-sav-v2-v3.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:parity": "vitest run tests/parity/runParity.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@duckdb/duckdb-wasm": "1.33.1-dev18.0",
    "@duckdb/node-api": "^1.4.4-r.1",
    "@monaco-editor/react": "^4.6.0",
    "@types/d3-hexbin": "^0.2.5",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "apache-arrow": "17.0.0",
    "commander": "^14.0.3",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-brush": "^3.0.0",
    "d3-hexbin": "^0.2.2",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.27.0",
    "jsavvy": "^0.0.6",
    "lucide-react": "^0.562.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^2.2.6",
    "webr": "^0.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@playwright/test": "^1.58.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.23",
    "happy-dom": "^15.11.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^2.1.9"
  }
}
