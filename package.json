{
  "name": "velocity",
  "private": true,
  "version": "0.1.0-pilot",
  "type": "module",
  "workspaces": [
    "packages/*",
    "mcp-server"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "clean": "node scripts/clean.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:mcp": "tsc --noEmit -p mcp-server/tsconfig.json",
    "typecheck:all": "npm run typecheck && npm run typecheck:test && npm run typecheck:mcp",
    "ci": "npm run lint && npm run check:eslint-ratchet && npm run check:e2e-companion && npm run format:check && npm run typecheck:all && npm run check:worker-boundary && npm run check:querybuilder-pure && npm run check:design-tokens && npm run test:run -- --coverage && npm run build",
    "ci:e2e": "npm run test:e2e",
    "check:worker-boundary": "node scripts/check-worker-boundary.mjs",
    "check:querybuilder-pure": "node scripts/check-querybuilder-pure.mjs",
    "check:design-tokens": "node scripts/check-design-tokens.mjs",
    "check:eslint-ratchet": "node scripts/check-eslint-ratchet.mjs",
    "check:e2e-companion": "node scripts/check-e2e-companion.mjs",
    "velocity-mcp-setup": "node scripts/velocity-mcp-setup.mjs",
    "mcp:build": "vitest run mcp-server/__tests__/tools.test.ts",
    "mcp:dev": "npm run dev -w @velocity/mcp-server",
    "eval:05": "node scripts/eval/run-eval-05.mjs",
    "eval:05b": "node scripts/eval/run-eval-05b.mjs",
    "eval:05b:engine": "tsx evals/eval-05/scripts/run_fuzzy_harmonization.ts",
    "eval:06": "node scripts/eval/run-eval-06.mjs",
    "benchmark:sav": "npx tsx scripts/benchmark-sav-ingestion.ts",
    "benchmark:sav:v2v3": "npx tsx scripts/benchmark-sav-v2-v3.ts",
    "benchmark:crosstab": "npx tsx scripts/benchmark-crosstab-render.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:parity": "vitest run tests/parity/runParity.test.ts",
    "test:mutation": "stryker run",
    "test:mutation:ci": "stryker run --concurrency 2",
    "test:e2e": "playwright test",
    "test:e2e:production": "playwright test --config playwright.production.config.ts",
    "benchmark:perf": "playwright test --config playwright.performance.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:visual-polish": "playwright test tests/e2e/visual-polish-theme-table.spec.ts",
    "test:e2e:visual-polish:update": "playwright test tests/e2e/visual-polish-theme-table.spec.ts --update-snapshots",
    "demo:run:first-analysis": "node demo/scripts/run-demo-flow.mjs --contract demo/contracts/first-analysis.json",
    "demo:run:deck-export-complete": "node demo/scripts/run-demo-flow.mjs --contract demo/contracts/deck-export-complete.json",
    "report-quality:inspect": "node scripts/report-quality/inspect-pptx.mjs",
    "report-quality:review": "node scripts/report-quality/review-artifact.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@duckdb/duckdb-wasm": "1.33.1-dev18.0",
    "@duckdb/node-api": "^1.4.4-r.1",
    "@monaco-editor/react": "^4.6.0",
    "@types/d3-hexbin": "^0.2.5",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "apache-arrow": "17.0.0",
    "commander": "^14.0.3",
    "d3-array": "^3.2.4",
    "d3-axis": "^3.0.0",
    "d3-brush": "^3.0.0",
    "d3-hexbin": "^0.2.2",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.27.0",
    "jsavvy": "^0.0.6",
    "jszip": "^3.10.1",
    "lucide-react": "^0.562.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-virtualized-auto-sizer": "^2.0.2",
    "react-window": "^2.2.6",
    "webr": "^0.4.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@playwright/test": "^1.58.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10.4.23",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^15.11.7",
    "postcss": "^8.5.6",
    "prettier": "^3.9.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.2.0",
    "vitest": "^2.1.9"
  }
}
